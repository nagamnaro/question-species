NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — required for npm run backfill-insights (never expose to the browser).
# Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Free hosted LLM (Groq) — runs in Groq's cloud, called from your deployed app.
# Sign up: https://console.groq.com — free tier, no local install needed.
# Add GROQ_API_KEY in Vercel/hosting env vars for production.
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant
# GROQ_TIMEOUT_MS=30000

# Magic-link email (production) — bypasses Supabase 2 emails/hour built-in cap.
# Resend: https://resend.com — use a verified sender address/domain.
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=Question Species <auth@yourdomain.com>

# Without GROQ_API_KEY, insights use a built-in heuristic (free, always works).
